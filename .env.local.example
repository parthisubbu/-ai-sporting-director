# Supabase — get these from your project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-side only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# AI Provider Configuration
# Provider type: openai, groq, together, openrouter, custom
AI_PROVIDER=groq

# API Key for the chosen provider
AI_API_KEY=

# Base URL for the AI provider (defaults to provider-specific URL if not set)
# Groq: https://api.groq.com/openai/v1
# OpenAI: https://api.openai.com/v1
# Together AI: https://api.together.xyz/v1
# OpenRouter: https://openrouter.io/api/v1
AI_BASE_URL=

# Model ID to use
# Groq examples: llama-3.1-70b-versatile, mixtral-8x7b-32768, gemma-7b-it
# OpenAI examples: gpt-4-turbo, gpt-3.5-turbo
# Together AI examples: meta-llama/Llama-3-70b-chat-hf
AI_MODEL=

# Public app URL — used in server actions and redirects
# Development: http://localhost:3000
NEXT_PUBLIC_APP_URL=

# Parser Service
# URL to the FC save-file parser microservice (default: http://localhost:3001)
PARSER_SERVICE_URL=http://localhost:3001
